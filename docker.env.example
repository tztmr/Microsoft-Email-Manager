# Microsoft-Email-Manager API 服务 - Docker环境变量配置示例
# 复制此文件为 .env 并根据需要修改配置

# =============================================================================
# 服务配置
# =============================================================================

# 服务监听地址（默认: 0.0.0.0）
HOST=0.0.0.0

# 服务监听端口（默认: 8000）
PORT=8000

# 工作进程数（默认: 1，建议设置为CPU核心数）
WORKERS=1

# =============================================================================
# Python运行时配置
# =============================================================================

# 禁用Python字节码文件生成（默认: 1）
PYTHONDONTWRITEBYTECODE=1

# 强制Python输出不缓冲（默认: 1）
PYTHONUNBUFFERED=1

# =============================================================================
# 应用配置
# =============================================================================

# 日志级别（可选: DEBUG, INFO, WARNING, ERROR）
LOG_LEVEL=INFO

# 是否启用调试模式（默认: false）
DEBUG=false

# 允许跨域调用 API 的来源，多个用英文逗号分隔；留空表示不启用跨域
# 示例: CORS_ALLOW_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOW_ORIGINS=

# 仅在前面明确有受信任反向代理时启用，允许读取 X-Forwarded-* 头
TRUST_PROXY_HEADERS=false

# 管理员登录失败限制
ADMIN_LOGIN_FAILURE_LIMIT=5
ADMIN_LOGIN_FAILURE_WINDOW_MINUTES=15
ADMIN_LOGIN_LOCKOUT_MINUTES=15

# Refresh Token 定时更新配置
# 是否启用后台定时刷新
REFRESH_TOKEN_AUTO_UPDATE_ENABLED=true
# 距离上次成功刷新满多少天后再次刷新
REFRESH_TOKEN_AUTO_UPDATE_INTERVAL_DAYS=30
# 后台任务每隔多少小时检查一次是否有账号到期
REFRESH_TOKEN_AUTO_UPDATE_CHECK_INTERVAL_HOURS=6
# 上次刷新失败后，最短隔多少小时再重试
REFRESH_TOKEN_AUTO_UPDATE_RETRY_HOURS=24
# 定时刷新日志最多保留多少条
REFRESH_TOKEN_UPDATE_LOG_LIMIT=500

# =============================================================================
# IMAP配置（已内置，通常无需修改）
# =============================================================================

# Outlook IMAP服务器（默认: outlook.live.com）
# IMAP_SERVER=outlook.live.com

# IMAP端口（默认: 993）
# IMAP_PORT=993

# =============================================================================
# 使用说明
# =============================================================================

# 1. 复制此文件：cp docker.env.example .env
# 2. 根据需要修改配置值
# 3. 在 docker-compose.yml 中引用：env_file: .env
# 4. 重启Docker服务：docker compose restart
#
# =============================================================================
# Docker 构建源配置（可选）
# =============================================================================
#
# 默认可配合 ./resolve-docker-build-env.sh 自动探测网络区域：
# - 中国大陆网络优先使用国内镜像源
# - 非中国大陆网络优先使用官方源
#
# 如需手动强制指定，可取消下面注释：
#
# MIRROR_REGION=auto
# BASE_IMAGE=python:3.11-alpine3.21
# PIP_INDEX_URL=https://pypi.org/simple
# PIP_TRUSTED_HOST=
#
# 国内网络可选示例：
# BASE_IMAGE=docker.m.daocloud.io/library/python:3.11-alpine3.21
# PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
# PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn
